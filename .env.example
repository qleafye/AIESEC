# Example .env file for the bot
# Make a copy of this file named ".env" and fill in your values.

# Bot token from BotFather
BOT_TOKEN=123456789:ABCDefGHIjkLLmnoPQRstuVWxyz

# List of admin Telegram IDs (comma separated or JSON list format)
ADMIN_IDS=[12345678, 87654321]

# Proxy settings (optional, if needed to connect to Telegram API)
# Format: http://user:pass@host:port or socks5://user:pass@host:port
# PROXY_URL=http://user:pass@1.2.3.4:8080

# Google Sheets Configuration
# ID of the Google Sheet (from URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to the service account credentials JSON file (relative to project root)
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# Toggle features
IS_DATE_CONFIRMED=True
IS_PLACE_CONFIRMED=False
